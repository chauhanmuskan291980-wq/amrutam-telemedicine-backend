# Application
APP_NAME=Amrutam Telemedicine Backend
APP_ENV=development
APP_DEBUG=true

# Database
# For local PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/amrutam_db

# For Docker Compose, use this instead:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/amrutam_db

# Redis
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URL=memory://

# For Docker Compose with Redis, use this instead:
# REDIS_ENABLED=true
# REDIS_URL=redis://redis:6379/0
# RATE_LIMIT_STORAGE_URL=redis://redis:6379/1

# JWT Authentication
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7